rules_version = '2';

// Sherwood Connect access model:
// - Managers can create logs they own and read/update/delete only their own.
// - The master account (hadiabdul8128@gmail.com) can read every log.
// - Manager profiles are private to the owner (master can read them too).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMaster() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() == 'hadiabdul8128@gmail.com';
    }

    function ownsIncoming() {
      return isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerEmail == request.auth.token.email;
    }

    function ownsExisting() {
      return isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /logs/{logId} {
      allow read: if isMaster() || ownsExisting();
      allow create: if ownsIncoming();
      allow update: if isMaster() || (ownsExisting() && ownsIncoming());
      allow delete: if isMaster() || ownsExisting();
    }

    match /managers/{uid} {
      allow read: if isMaster() || (isSignedIn() && request.auth.uid == uid);
      allow write: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
